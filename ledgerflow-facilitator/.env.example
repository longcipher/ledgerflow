# LedgerFlow Facilitator environment variables

# Server configuration (overrides config.toml)
LEDGERFLOW_FAC__HOST=0.0.0.0
LEDGERFLOW_FAC__PORT=3402

# Logging
RUST_LOG=info

# EVM signer private key (hex, for settlement; referenced by signer_key_env in config)
# EVM_SIGNER_PRIVATE_KEY=0xYourPrivateKeyHere

# API keys for offchain HTTP backends (referenced by api_key_env in config)
# BINANCE_BRIDGE_API_KEY=your-key-here
